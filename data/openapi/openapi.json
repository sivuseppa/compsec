{
  "openapi": "3.0.0",
  "info": {
    "version": "1.0.0",
    "title": "CompSec App",
    "license": {
      "name": "MIT"
    }
  },
  "servers": [
    {
      "url": ""
    }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Run get actions on App.",
        "parameters": [
          {
            "name": "getUser",
            "in": "query",
            "description": "How many items to return at one time (max 100)",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "format": "int32"
            }
          }
        ]
      },
      "post": {
        "summary": "Run post actions on App.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/User"
              }
            }
          },
          "required": true
        }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "required": [],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}
